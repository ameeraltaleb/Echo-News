# Required Environment Variables for Echo News

# Database Configuration
# PostgreSQL connection string (required)
POSTGRES_URL="postgresql://user:password@host:port/database"
# Alternative database URL
DATABASE_URL="postgresql://user:password@host:port/database"

# Security (Required for Production)
# JWT secret key - MUST be at least 32 characters long
JWT_SECRET="your-super-secret-jwt-key-minimum-32-characters-long"

# Admin password - REQUIRED, no default value in production
ADMIN_PASSWORD="your-secure-admin-password"

# API Keys (Optional - only if using these features)
# Gemini AI API key for article generation
GEMINI_API_KEY="your-gemini-api-key"

# Unsplash API key for image search
UNSPLASH_ACCESS_KEY="your-unsplash-access-key"

# Supabase configuration (if using Supabase storage)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"

# Application Configuration
# The URL where this applet is hosted
APP_URL="https://your-domain.com"

# Node environment
NODE_ENV="production"
